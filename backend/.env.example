APP_NAME="Digital Courses"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null

# Usuário Administrador Inicial do Sistema (Seeder)
ADMIN_NAME=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Banco de Dados
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=digital_courses
DB_USERNAME=laravel
DB_PASSWORD=""

POSTGRES_DB=digital_courses
POSTGRES_USER=laravel
POSTGRES_PASSWORD=""

# pgAdmin (UI de Gerenciamento)
PGADMIN_DEFAULT_EMAIL=""
PGADMIN_DEFAULT_PASSWORD=""

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_PORT=6379
REDIS_HOST=redis
REDIS_PASSWORD=null

# E-MAIL / SMTP
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@digitalcourses.com"
MAIL_FROM_NAME="${APP_NAME}"

# Armazenamento MinIO (S3 Local)
MINIO_ROOT_USER=""
MINIO_ROOT_PASSWORD=""

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=digital-courses-bucket
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

VITE_APP_NAME="${APP_NAME}"

# Swagger / OpenAPI
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:8000
L5_SWAGGER_BASE_PATH=/api/v1
L5_SWAGGER_USE_ABSOLUTE_PATH=true

# SEGURANÇA: Acesso ao Swagger UI
SWAGGER_ENABLED=true
SWAGGER_USER=admin
SWAGGER_PASSWORD=""
